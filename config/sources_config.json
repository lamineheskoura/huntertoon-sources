    "azora": {
      "enabled": true,
      "name": "أزورا مون (AzoraMoon)",
      "base_url": "https://azoramoon.com",
      "api_base": "https://api.azoramoon.com",
      "headers": {
        "User-Agent": "Mozilla/5.0 (Linux; Android 10; K) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Mobile Safari/537.36",
        "Accept-Language": "ar,en-US;q=0.9,en;q=0.8",
        "Referer": "https://azoramoon.com/",
        "Origin": "https://azoramoon.com",
        "Sec-Ch-Ua": "\"Chromium\";v=\"122\", \"Not(A:Brand\";v=\"24\", \"Google Chrome\";v=\"122\"",
        "Sec-Ch-Ua-Mobile": "?1",
        "Sec-Ch-Ua-Platform": "\"Android\"",
        "Sec-Fetch-Dest": "empty",
        "Sec-Fetch-Mode": "cors",
        "Sec-Fetch-Site": "same-site"
      },
      "selectors": {
        "manga_title": "meta[property='og:title']",
        "manga_cover": "meta[property='og:image']",
        "manga_description": "meta[name='description']",
        "chapter_list": "a[href*='/chapter-']",
        "chapter_title": "الفصل {number}",
        "chapter_page_image": "img[data-image-index]"
      },
      "regex": {
        "chapter_number": "/chapter-(\\d+(?:\\.\\d+)?)",
        "slug": "/series/([^/?#]+)"
      },
      "other": {
        "uses_nextjs_api": true,
        "is_nsfw": false
      }
    },
