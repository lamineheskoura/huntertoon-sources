      },
      "selectors": {
        "api_list": "https://dilar.tube/api/series?page={page}&search={query}",
        "api_details": "https://dilar.tube/api/series/{id}",
        "api_chapters": "https://dilar.tube/api/chapters/{id}",
        "cover_url_pattern": "https://dilar.tube/uploads/manga/cover/{id}/large_{filename}",
        "page_url_pattern": "https://dilar.tube/uploads/releases/{storage_key}/hq/{filename}",
        "manga_title": "h1, meta[property='og:title']",
        "manga_cover": ".series-cover img, img[alt*='cover'], meta[property='og:image'], div.relative img",
        "manga_description": ".series-story, p.text-gray-300.line-clamp-4, .description, meta[name='description']",
        "manga_genres": ".bg-primary\\\\/10, div.flex.flex-wrap.gap-2 a, a[href*='/genre/']",
        "chapter_list": ".chapter-item a, a[href*='/chapter/'], a[href*='/ch-'], a.flex.items-center.justify-between",
        "chapter_page_image": ".reader-image img, div.flex.flex-col.items-center img",
        "filter_list": "a[href*='/series/'], div.grid a.w-full.h-full",
        "filter_title": "h3",
        "filter_cover": "img[src*='/uploads/'], div[style*='background-image'], img"
      },
      "regex": {
        "chapter_number": "(?:chapter|ch|episode|-f|/)\\\\D*?(\\\\d+(?:\\\\.\\\\d+)?)"
      },
      "other": {
        "icon_asset": "assets/icons/dilar.png",
        "theme": "api",
        "is_nsfw": false
      }
    },
